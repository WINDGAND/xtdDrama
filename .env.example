# 小题大Drama — 环境变量模板（不要填写真实密钥后提交）

# ── HY Token Plan：纯文本模型（Guess / NPC / Vision 文本兜底）─
TOKENHUB_API_KEY=sk-tp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOKENHUB_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3
TOKENHUB_GUESS_MODEL=hy3-preview
TOKENHUB_EMOTION_MODEL=hy3-preview
TOKENHUB_NPC_MODEL=hy3-preview

# ── 通用 Token Plan / MaaS：多模态视觉 + 生图 + 生视频 ──
TOKENHUB_MAAS_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOKENHUB_MAAS_BASE_URL=https://tokenhub.tencentmaas.com
TOKENHUB_VITA_MODEL=youtu-vita
TOKENHUB_IMAGE_MODEL=hy-image-v3.0
TOKENHUB_VIDEO_MODEL=hy-video-1.5

# 上游请求超时（毫秒）
TOKENHUB_TIMEOUT_MS=30000
TOKENHUB_MAX_TOKENS=512

# ── Supabase 服务端 ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=xtd-drama
SUPABASE_AVATAR_BUCKET=avatars

# ── Supabase 浏览器端 ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
